# Copy this file to secrets.toml (same directory) for local development,
# or paste these key/value pairs into the "Secrets" editor in
# Streamlit Community Cloud (Manage app -> Settings -> Secrets).
#
# DO NOT COMMIT secrets.toml -- it is already in .gitignore.

SF_USER      = "your_snowflake_username"
SF_ACCOUNT   = "UNB02139"
SF_WAREHOUSE = "LEMMING_WH"
SF_DATABASE  = "LEMMING_DB"
SF_SCHEMA    = "FINAL_PROJECT_MART"  # optional, defaults to FINAL_PROJECT_MART

# --- Snowflake key-pair auth ---------------------------------------------
# Use ONE of the two options below.

# Option A (recommended for Streamlit Community Cloud):
# Paste the full PEM text of your private key as a triple-quoted string.
# Include the BEGIN/END lines exactly as they appear in the .p8 file.
SF_PRIVATE_KEY = """
-----BEGIN PRIVATE KEY-----
MIIEv...your...key...lines...here...
...
-----END PRIVATE KEY-----
"""

# Option B (local dev only): point to a .p8 file on disk.
# SF_PRIVATE_KEY_PATH = "/absolute/path/to/rsa_key.p8"

# Optional: only set if your private key is encrypted.
# SF_PRIVATE_KEY_PASSWORD = "your_passphrase"
